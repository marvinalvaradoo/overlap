---
import { Icon } from 'astro-icon/components';
---

<section id="inicio" class="noise-bg" style="
  position: relative;
  min-height: 100vh;
  background: var(--black);
  display: flex;
  align-items: center;
  overflow: hidden;
">

  <!-- Subtle grid -->
  <div style="
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.022) 1px, transparent 1px);
    background-size: 72px 72px;
  "></div>

  <!-- Yellow radial glow — bottom center -->
  <div style="
    position: absolute; bottom: -80px; left: 50%; transform: translateX(-50%);
    width: 900px; height: 400px;
    background: radial-gradient(ellipse at center, rgba(245,200,0,.09) 0%, transparent 70%);
    pointer-events: none; z-index: 0;
  "></div>

  <!-- Mobile bottom fade — helps stats bar legibility -->
  <div class="hero-bottom-fade" style="
    display: none;
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 180px;
    background: linear-gradient(to top, rgba(10,10,10,.95) 0%, transparent 100%);
    pointer-events: none; z-index: 4;
  "></div>

  <!-- Right-side glow behind vehicle -->
  <div style="
    position: absolute; right: -100px; top: 50%; transform: translateY(-50%);
    width: 700px; height: 700px;
    background: radial-gradient(ellipse at center, rgba(245,200,0,.06) 0%, transparent 65%);
    pointer-events: none; z-index: 0;
  "></div>

  <!-- ── Content ── -->
  <div style="
    position: relative; z-index: 2;
    width: 100%; max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    padding-top: 96px;
    padding-bottom: 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    min-height: 100vh;
  " class="hero-grid">

    <!-- ── Left: copy ── -->
    <div class="hero-copy" style="display:flex;flex-direction:column;justify-content:center">

      <!-- Eyebrow -->
      <div class="reveal" style="
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.75rem;
      ">
        <div style="width:28px;height:1px;background:var(--yellow)"></div>
        <span style="
          font-family: var(--font-body);
          font-size: .7rem;
          font-weight: 600;
          letter-spacing: .3em;
          text-transform: uppercase;
          color: var(--yellow);
        ">Blindaje Automotriz · Guatemala</span>
      </div>

      <!-- H1 -->
      <h1 class="reveal" style="
        font-family: var(--font-display);
        font-size: clamp(64px, 8.5vw, 112px);
        line-height: .93;
        color: #fff;
        margin-bottom: 1.75rem;
        transition-delay: .08s;
      ">
        Avanza.<br />
        <span style="color:var(--yellow)">Estás</span><br />
        protegido.
      </h1>

      <!-- Subtitle -->
      <p class="reveal hero-subtitle" style="
        font-size: 1.15rem;
        line-height: 1.75;
        color: rgba(255,255,255,.52);
        max-width: 400px;
        margin-bottom: 2.5rem;
        transition-delay: .16s;
      ">
        Tecnología balística certificada. Discreción absoluta.<br />
        Sin comprometer el lujo de tu vehículo.
      </p>

      <!-- CTAs -->
      <div class="reveal hero-ctas" style="
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 3.5rem;
        transition-delay: .24s;
      ">
        <a href="#contacto" class="btn-primary">Cotizar Ahora</a>
        <a href="tel:+50242453899" class="hero-phone" style="
          display: flex;
          align-items: center;
          gap: .6rem;
          font-size: .88rem;
          font-weight: 500;
          color: rgba(255,255,255,.6);
          text-decoration: none;
          transition: color .2s ease;
          letter-spacing: .04em;
        "
        onmouseover="this.style.color='var(--yellow)'"
        onmouseout="this.style.color='rgba(255,255,255,.6)'">
          <Icon name="tabler:phone" style="width:16px;height:16px;color:var(--yellow);flex-shrink:0" />
          +502 4245 3899
        </a>
      </div>

      <!-- Stats bar (desktop only — hidden on mobile) -->
      <div class="reveal hero-stats hero-stats-desktop" style="
        display: flex;
        align-items: center;
        gap: 2.5rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,.08);
        transition-delay: .32s;
      ">
        <div>
          <p style="font-family:var(--font-display);font-size:1.9rem;color:var(--yellow);line-height:1">3 años</p>
          <p style="font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.35rem">Garantía</p>
        </div>
        <div class="hero-stats-divider" style="width:1px;height:36px;background:rgba(255,255,255,.1)"></div>
        <div>
          <p style="font-family:var(--font-display);font-size:1.9rem;color:#fff;line-height:1">NIJ & CEN</p>
          <p style="font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.35rem">Certificaciones</p>
        </div>
        <div class="hero-stats-divider" style="width:1px;height:36px;background:rgba(255,255,255,.1)"></div>
        <div>
          <p style="font-family:var(--font-display);font-size:1.9rem;color:#fff;line-height:1">II — V</p>
          <p style="font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.35rem">Niveles</p>
        </div>
      </div>
    </div>

    <!-- ── Right: vehicle ── -->
    <div class="reveal hero-vehicle-wrap" style="
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      transition-delay: .1s;
    ">
      <!-- Glow under car -->
      <div class="hero-car-glow" style="
        position: absolute;
        bottom: 5%;
        left: 50%; transform: translateX(-50%);
        width: 80%;
        height: 120px;
        background: rgba(245,200,0,.18);
        filter: blur(55px);
        border-radius: 50%;
        pointer-events: none;
      "></div>

      <img
        src="/assets/Niveles_Nivel III.png"
        alt="Vehículo blindado Overlap"
        style="
          position: relative;
          z-index: 2;
          width: 100%;
          max-width: 680px;
          object-fit: contain;
          filter: drop-shadow(0 20px 60px rgba(245,200,0,.14));
        "
      />
    </div>
  </div>

  <!-- Stats bar (mobile only — pinned to section bottom) -->
  <div class="hero-stats-wrap" style="display:none">
    <div class="hero-stats-mobile" style="
      display: flex;
      align-items: center;
    ">
      <div style="flex:1;text-align:center">
        <p style="font-family:var(--font-display);font-size:1.3rem;color:var(--yellow);line-height:1">3 años</p>
        <p style="font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.2rem">Garantía</p>
      </div>
      <div style="width:1px;height:28px;background:rgba(255,255,255,.12);flex-shrink:0"></div>
      <div style="flex:1;text-align:center">
        <p style="font-family:var(--font-display);font-size:1.3rem;color:#fff;line-height:1">NIJ & CEN</p>
        <p style="font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.2rem">Certificaciones</p>
      </div>
      <div style="width:1px;height:28px;background:rgba(255,255,255,.12);flex-shrink:0"></div>
      <div style="flex:1;text-align:center">
        <p style="font-family:var(--font-display);font-size:1.3rem;color:#fff;line-height:1">II — V</p>
        <p style="font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.2rem">Niveles</p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="
    position: absolute;
    right: 2rem; bottom: 2.5rem;
    display: flex; flex-direction: column; align-items: center; gap: .75rem;
    z-index: 3;
  " class="scroll-hint">
    <span style="
      font-size: .6rem;
      letter-spacing: .32em;
      text-transform: uppercase;
      color: rgba(255,255,255,.25);
      writing-mode: vertical-rl;
    ">Scroll</span>
    <div style="width:1px;height:56px;background:linear-gradient(to bottom,rgba(255,255,255,.2),transparent);position:relative;overflow:hidden">
      <div class="scroll-drop" style="position:absolute;top:0;left:0;width:100%;height:20px;background:var(--yellow)"></div>
    </div>
  </div>
</section>

<style>
  /* ── Tablet ── */
  @media (max-width: 1023px) {
    .hero-grid {
      grid-template-columns: 1fr !important;
      padding-top: 100px !important;
      min-height: unset !important;
      gap: 1.5rem !important;
    }
    .scroll-hint { display: none !important; }
    .hero-vehicle-wrap img { max-width: 480px !important; }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    #inicio {
      min-height: 100svh !important;
      align-items: flex-start !important;
    }
    .hero-bottom-fade { display: block !important; }

    /* Grid → flex column, fills full viewport */
    .hero-grid {
      display: flex !important;
      flex-direction: column !important;
      padding: 0 !important;
      gap: 0 !important;
      min-height: 100svh !important;
      position: relative !important;
    }

    /* Copy: top section with padding */
    .hero-copy {
      padding: 96px 1.4rem 1.25rem !important;
      flex-shrink: 0;
    }
    .hero-copy h1 {
      font-size: clamp(54px, 15vw, 76px) !important;
      margin-bottom: .85rem !important;
    }
    .hero-subtitle {
      font-size: 1rem !important;
      line-height: 1.7 !important;
      margin-bottom: 1.25rem !important;
      max-width: 100% !important;
    }

    /* CTAs: full-width */
    .hero-ctas {
      flex-direction: column !important;
      align-items: stretch !important;
      gap: .65rem !important;
      margin-bottom: 0 !important;
    }
    .hero-ctas .btn-primary {
      width: 100% !important;
      justify-content: center !important;
    }
    .hero-ctas .hero-phone { justify-content: center !important; }

    /* Desktop stats: hidden on mobile */
    .hero-stats-desktop { display: none !important; }

    /* Vehicle: fills remaining space, oversized for drama */
    .hero-vehicle-wrap {
      flex: 1 !important;
      width: 100% !important;
      padding: 0 !important;
      margin-top: -.5rem !important;
      display: flex !important;
      align-items: flex-end !important;
      justify-content: center !important;
      padding-bottom: 72px !important; /* space for stats bar */
    }
    .hero-vehicle-wrap img {
      width: 120% !important;
      max-width: 120% !important;
      margin-left: -10% !important;
      filter: drop-shadow(0 16px 48px rgba(245,200,0,.25)) !important;
    }
    .hero-vehicle-wrap .hero-car-glow {
      width: 100% !important;
      height: 180px !important;
      background: rgba(245,200,0,.2) !important;
      filter: blur(60px) !important;
      bottom: 10% !important;
    }

    /* Mobile stats bar: shown, pinned to section bottom */
    .hero-stats-wrap {
      display: block !important;
      position: absolute !important;
      bottom: 0 !important;
      left: 0 !important;
      right: 0 !important;
      z-index: 6;
      background: rgba(10,10,10,.88) !important;
      backdrop-filter: blur(14px) !important;
      -webkit-backdrop-filter: blur(14px) !important;
      border-top: 1px solid rgba(255,255,255,.1) !important;
      padding: .85rem 1.25rem !important;
    }
  }
</style>
