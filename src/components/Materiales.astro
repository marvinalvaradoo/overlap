---
import { Icon } from 'astro-icon/components';

const materiales = [
  {
    num: '01',
    titulo: 'Vidrios Blindados',
    descripcion: 'Marca Óptima, importados de Colombia. 21mm con pestañas de acero, tintes de fábrica. Certificación NIJ y CEN. Máxima claridad óptica y resistencia balística.',
    icon: 'tabler:eye',
    tags: ['NIJ Certificado', 'CEN Certificado', '21mm'],
  },
  {
    num: '02',
    titulo: 'Acero Balístico & Kevlar',
    descripcion: 'Grado militar 1/8". Protege puertas, compuerta, faldones, tablero, parales, techo y corona. El piso con tela Anti-esquirlas para protección integral.',
    icon: 'tabler:shield',
    tags: ['Grado Militar', 'Anti-esquirlas', '1/8"'],
  },
  {
    num: '03',
    titulo: 'Suspensión Old Man Emu',
    descripcion: 'Importada de Australia. Incluida en Niveles IV y V para compensar el incremento de peso del blindaje, manteniendo el rendimiento y la conducción original.',
    icon: 'tabler:settings',
    tags: ['Australia', 'Niveles IV & V', 'Alto rendimiento'],
  },
];
---

<section class="section-pad" style="background:#fff;position:relative;overflow:hidden">

  <!-- Decorative watermark -->
  <div style="
    position:absolute;right:-1rem;top:50%;transform:translateY(-50%);
    font-family:var(--font-display);font-size:220px;
    color:rgba(10,10,10,.03);line-height:1;
    user-select:none;pointer-events:none;z-index:0;
    display:none;
  " class="watermark">OVERLAP</div>

  <div style="position:relative;z-index:2;max-width:1400px;margin:0 auto">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;flex-wrap:wrap;margin-bottom:4rem" class="reveal">
      <div>
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem">
          <div style="width:28px;height:2px;background:var(--yellow)"></div>
          <span style="font-family:var(--font-body);font-size:.7rem;font-weight:600;letter-spacing:.3em;text-transform:uppercase;color:var(--yellow)">Materiales</span>
        </div>
        <h2 style="font-family:var(--font-display);font-size:clamp(40px,5.5vw,72px);color:var(--black);line-height:.95">
          Cada capa.<br />Cada milímetro.<br />
          <span style="color:var(--yellow)">Certificado.</span>
        </h2>
      </div>
      <p style="color:rgba(10,10,10,.5);font-size:1rem;line-height:1.75;max-width:360px" class="mat-header-sub">
        Usamos únicamente materiales con certificación internacional. Sin atajos. Sin compromisos.
      </p>
    </div>

    <!-- Cards -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem" class="mat-grid">
      {materiales.map((m, i) => (
        <div class="mat-card reveal" style={`
          position:relative;overflow:hidden;
          background:#fff;
          border:1px solid rgba(10,10,10,.08);
          padding:2.5rem;
          transition:border-color .3s ease, box-shadow .3s ease, transform .3s ease;
          transition-delay:${i * .1}s;
        `}>
          <!-- Top accent bar -->
          <div class="mat-top-bar" style="
            position:absolute;top:0;left:0;right:0;height:3px;
            background:var(--yellow);
            transform:scaleX(0);transform-origin:left;
            transition:transform .35s ease;
          "></div>

          <!-- Large number watermark -->
          <span class="mat-num" style="
            position:absolute;bottom:-.5rem;right:1rem;
            font-family:var(--font-display);font-size:96px;
            color:rgba(10,10,10,.04);line-height:1;
            user-select:none;
            transition:color .3s ease;
          ">{m.num}</span>

          <div style="position:relative;z-index:2">
            <!-- Icon -->
            <div class="mat-icon-box" style="
              width:48px;height:48px;
              background:var(--black);
              display:flex;align-items:center;justify-content:center;
              margin-bottom:2rem;
              transition:background .3s ease;
            ">
              <Icon name={m.icon} style="width:22px;height:22px;color:var(--yellow)" />
            </div>

            <!-- Number label -->
            <p style="font-family:var(--font-body);font-size:.65rem;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:rgba(10,10,10,.25);margin-bottom:.5rem">{m.num}</p>

            <!-- Title -->
            <h3 style="font-family:var(--font-display);font-size:clamp(20px,2vw,26px);color:var(--black);margin-bottom:1rem;line-height:1.1">{m.titulo}</h3>

            <!-- Description -->
            <p style="color:rgba(10,10,10,.55);font-size:1.05rem;line-height:1.75;margin-bottom:1.75rem">{m.descripcion}</p>

            <!-- Tags -->
            <div style="display:flex;flex-wrap:wrap;gap:.5rem">
              {m.tags.map(tag => (
                <span style="
                  font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;
                  font-weight:600;
                  color:var(--black);
                  background:rgba(10,10,10,.06);
                  padding:.35rem .85rem;
                ">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA strip -->
    <div class="reveal mat-cta-strip" style="
      margin-top:2rem;
      background:var(--black);
      padding:2rem 2.5rem;
      display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1.5rem;
    ">
      <div style="display:flex;align-items:center;gap:1.25rem">
        <div style="width:40px;height:40px;border:1px solid rgba(245,200,0,.4);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <Icon name="tabler:message-circle" style="width:18px;height:18px;color:var(--yellow)" />
        </div>
        <div>
          <p style="font-family:var(--font-body);font-size:.68rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--yellow);margin-bottom:.25rem">¿Tienes dudas sobre los materiales?</p>
          <p style="color:rgba(255,255,255,.45);font-size:1.05rem" class="mat-cta-body">Nuestro equipo técnico puede asesorarte sin compromiso.</p>
        </div>
      </div>
      <a href="#contacto" class="btn-primary">Hablar con un experto</a>
    </div>

  </div>
</section>

<style>
  .watermark { display: none; }
  @media (min-width: 1280px) { .watermark { display: block !important; } }

  @media (max-width: 767px) {
    .mat-grid { grid-template-columns: 1fr !important; }
    .mat-cta-strip { flex-direction: column !important; align-items: flex-start !important; gap: 1.25rem !important; }
    .mat-cta-strip a { width: 100% !important; justify-content: center !important; }
  }

  @media (max-width: 640px) {
    /* Card description text */
    .mat-card p[style*="1.05rem"] { font-size: 1rem !important; line-height: 1.8 !important; }
    /* Section subtitle */
    .mat-header-sub { font-size: 1rem !important; line-height: 1.8 !important; }
    /* CTA strip body text */
    .mat-cta-body { font-size: 1rem !important; }
  }

  .mat-card:hover {
    border-color: rgba(10,10,10,.18) !important;
    box-shadow: 0 12px 48px rgba(0,0,0,.1) !important;
    transform: translateY(-3px) !important;
  }
  .mat-card:hover .mat-top-bar  { transform: scaleX(1) !important; }
  .mat-card:hover .mat-num      { color: rgba(245,200,0,.12) !important; }
  .mat-card:hover .mat-icon-box { background: var(--yellow) !important; }
  .mat-card:hover .mat-icon-box svg { color: var(--black) !important; }
</style>
