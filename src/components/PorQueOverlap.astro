---
import { Icon } from 'astro-icon/components';

const features = [
  { icon: 'tabler:shield-check', text: 'Materiales balísticos certificados internacionalmente' },
  { icon: 'tabler:eye-off',      text: 'Proceso 100% discreto y confidencial' },
  { icon: 'tabler:tool',         text: 'Equipo técnico especializado con años de experiencia' },
  { icon: 'tabler:clock',        text: 'Entrega en 6 semanas con garantía por escrito' },
];
---

<section id="nosotros" class="section-pad overflow-hidden" style="background:#fff">
  <div class="max-w-[1400px] mx-auto">
    <div class="grid lg:grid-cols-[3fr_2fr] gap-16 lg:gap-24 items-center">

      <!-- Left -->
      <div>
        <p class="eyebrow mb-6 reveal">Acerca de Overlap</p>

        <h2 class="display reveal mb-8" style="font-size:clamp(40px,5.5vw,76px); color:var(--black); transition-delay:.1s">
          Protección que<br />se diseña.<br />
          <span style="color:var(--yellow)">No se improvisa.</span>
        </h2>

        <p class="reveal mb-12 porque-body-text" style="color:rgba(10,10,10,.58); font-size:1.15rem; line-height:1.8; max-width:560px; transition-delay:.2s">
          En Overlap combinamos tecnología balística de primer nivel, materiales certificados internacionalmente y un equipo altamente especializado. Cada vehículo es tratado con precisión quirúrgica para garantizar protección real sin comprometer rendimiento ni estética.
        </p>

        <!-- Stats -->
        <div class="stats-grid grid grid-cols-3 gap-5 reveal mb-12" style="transition-delay:.3s">
          {[
            { val:'3 años',   label:'Garantía por escrito',          accent:false },
            { val:'NIJ & CEN',label:'Certificaciones internacionales', accent:true  },
            { val:'II — V',   label:'Cobertura completa',             accent:false },
          ].map(s => (
            <div style={`border-top: 2px solid ${s.accent ? 'var(--yellow)' : 'rgba(10,10,10,.12)'}; padding-top:1.2rem; min-width:0`}>
              <p class="display" style="font-size:clamp(1.2rem,2.5vw,1.9rem); color:var(--black); margin-bottom:.3rem; white-space:nowrap">{s.val}</p>
              <p style="color:rgba(10,10,10,.38); font-size:.62rem; letter-spacing:.15em; text-transform:uppercase; line-height:1.5; word-break:break-word">{s.label}</p>
            </div>
          ))}
        </div>

        <!-- Feature list -->
        <ul class="flex flex-col gap-4 reveal" style="transition-delay:.4s">
          {features.map(f => (
            <li style="display:flex; align-items:center; gap:.85rem; color:rgba(10,10,10,.65); font-size:1.05rem" class="porque-feature-item">
              <Icon name={f.icon} style="width:20px;height:20px;flex-shrink:0;color:var(--yellow)" />
              {f.text}
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: image panel -->
      <div class="relative reveal" style="transition-delay:.2s">
        <div style="border-left:4px solid var(--yellow); overflow:hidden">
          <div style="aspect-ratio:4/5; background:transparent; position:relative; overflow:hidden; display:flex; align-items:center; justify-content:center" class="porque-img-wrap">
            <img src="/assets/icon-certificate.png"
                 alt="Taller Overlap"
                 style="width:100%; height:100%; object-fit:contain" />
          </div>
        </div>
        <!-- Badge -->
        <div class="hidden lg:block" style="position:absolute;bottom:-1.5rem;left:-1.5rem;background:var(--yellow);padding:1.2rem 1.5rem">
          <p class="display" style="font-size:2.2rem;color:var(--black);line-height:1">100%</p>
          <p style="color:rgba(10,10,10,.65);font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;margin-top:.3rem">Certificado</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @media (max-width: 767px) {
    .porque-img-wrap { aspect-ratio: 3/2 !important; }
  }

  @media (max-width: 640px) {
    .porque-body-text { font-size: 1.05rem !important; line-height: 1.85 !important; }
    .porque-feature-item { font-size: 1rem !important; }
    /* Stack stats vertically on small screens to prevent overlap */
    .stats-grid {
      grid-template-columns: 1fr !important;
      gap: 1.25rem !important;
    }
    /* Bigger stat values and labels on mobile */
    .stats-grid .display { font-size: 2rem !important; }
    .stats-grid p:last-child { font-size: .82rem !important; letter-spacing: .12em !important; }
  }
</style>
