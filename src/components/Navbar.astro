---
import { Icon } from 'astro-icon/components';

const links = [
  { href: '#inicio',    label: 'Inicio' },
  { href: '#blindajes', label: 'Blindajes' },
  { href: '#nosotros',  label: 'Nosotros' },
  { href: '#contacto',  label: 'Contacto' },
];
---

<header id="navbar" style="
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 50;
  transition: background .35s ease, border-color .35s ease;
">
  <div style="
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  ">

    <!-- Logo -->
    <a href="/" style="flex-shrink:0; display:flex; align-items:center; text-decoration:none">
      <img src="/assets/logo-white.png" alt="Overlap Guatemala"
           style="height:38px; width:auto; object-fit:contain; display:block" />
    </a>

    <!-- Desktop nav -->
    <nav style="display:flex; align-items:center; gap:2.5rem; flex:1; justify-content:center">
      {links.map(l => (
        <a href={l.href} class="nav-link" style="
          font-family: var(--font-body);
          font-size: .8rem;
          font-weight: 500;
          letter-spacing: .2em;
          text-transform: uppercase;
          color: rgba(255,255,255,.55);
          text-decoration: none;
          white-space: nowrap;
          transition: color .2s ease;
          padding: .25rem 0;
          position: relative;
        ">{l.label}</a>
      ))}
    </nav>

    <!-- Right: phone + CTA -->
    <div style="display:flex; align-items:center; gap:1.5rem; flex-shrink:0">
      <a href="tel:+50242453899" style="
        display: flex;
        align-items: center;
        gap: .5rem;
        font-family: var(--font-body);
        font-size: .82rem;
        font-weight: 500;
        color: var(--yellow);
        text-decoration: none;
        white-space: nowrap;
        transition: opacity .2s ease;
      ">
        <Icon name="tabler:phone" style="width:15px;height:15px;flex-shrink:0" />
        +502 4245 3899
      </a>
      <a href="#contacto" class="btn-primary" style="
        padding: .7rem 1.5rem;
        font-size: .72rem;
        letter-spacing: .18em;
        white-space: nowrap;
      ">Cotizar</a>
    </div>

    <!-- Hamburger (mobile) -->
    <button id="menu-toggle"
            aria-label="Abrir menú"
            style="
              display: none;
              flex-direction: column;
              gap: 5px;
              padding: .5rem;
              background: none;
              border: none;
              cursor: pointer;
            ">
      <span id="hb1" style="display:block;width:24px;height:2px;background:#fff;transition:all .3s ease;transform-origin:center"></span>
      <span id="hb2" style="display:block;width:24px;height:2px;background:#fff;transition:all .3s ease"></span>
      <span id="hb3" style="display:block;width:16px;height:2px;background:#fff;transition:all .3s ease;transform-origin:center"></span>
    </button>
  </div>
</header>

<!-- Mobile fullscreen menu -->
<div id="mobile-menu" style="
  position: fixed;
  inset: 0;
  z-index: 40;
  background: var(--black);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0;
  transform: translateX(100%);
  transition: transform .5s cubic-bezier(.77,0,.18,1);
">
  <nav style="display:flex;flex-direction:column;align-items:center;gap:1.5rem;margin-bottom:3rem">
    {links.map(l => (
      <a href={l.href} class="mobile-nav-link" style="
        font-family: var(--font-display);
        font-size: 3.2rem;
        color: #fff;
        text-decoration: none;
        letter-spacing: .04em;
        transition: color .2s ease;
      ">{l.label}</a>
    ))}
  </nav>
  <a href="#contacto" class="btn-primary mobile-nav-link">Cotizar Ahora</a>
  <a href="tel:+50242453899" class="mobile-nav-link" style="
    margin-top:1.5rem;
    display:flex;align-items:center;gap:.5rem;
    font-size:.9rem;font-weight:500;
    color:var(--yellow);text-decoration:none;
  ">
    <Icon name="tabler:phone" style="width:16px;height:16px" />
    +502 4245 3899
  </a>
</div>

<style>
  .nav-link:hover { color: #fff !important; }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0; right: 0;
    height: 1px;
    background: var(--yellow);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .25s ease;
  }
  .nav-link:hover::after { transform: scaleX(1); }
  .mobile-nav-link:hover { color: var(--yellow) !important; }

  @media (max-width: 1023px) {
    nav { display: none !important; }
    div[style*="gap:1.5rem"] { display: none !important; }
    #menu-toggle { display: flex !important; }
  }

  /* Mobile menu font scaling */
  @media (max-width: 480px) {
    #mobile-menu nav a { font-size: 2.4rem !important; }
    #mobile-menu nav { gap: 1rem !important; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar')!;
  const toggle = document.getElementById('menu-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;
  const hb1    = document.getElementById('hb1')!;
  const hb2    = document.getElementById('hb2')!;
  const hb3    = document.getElementById('hb3')!;
  let open = false;

  // Scroll: solidify navbar
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      navbar.style.background = 'rgba(10,10,10,.97)';
      navbar.style.borderBottom = '1px solid rgba(255,255,255,.07)';
      navbar.style.backdropFilter = 'blur(14px)';
    } else {
      navbar.style.background = '';
      navbar.style.borderBottom = '';
      navbar.style.backdropFilter = '';
    }
  });

  function openMenu() {
    open = true;
    menu.style.transform = 'translateX(0)';
    hb1.style.transform = 'translateY(7px) rotate(45deg)';
    hb2.style.opacity = '0';
    hb3.style.transform = 'translateY(-7px) rotate(-45deg)';
    hb3.style.width = '24px';
  }
  function closeMenu() {
    open = false;
    menu.style.transform = 'translateX(100%)';
    hb1.style.transform = '';
    hb2.style.opacity = '';
    hb3.style.transform = '';
    hb3.style.width = '';
  }

  toggle.addEventListener('click', () => open ? closeMenu() : openMenu());
  document.querySelectorAll('.mobile-nav-link').forEach(l => l.addEventListener('click', closeMenu));
</script>
