---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
}

const {
  title = 'Overlap Guatemala — Blindaje Automotriz Premium',
  description = 'Blindaje automotriz certificado NIJ y CEN en Guatemala. Tecnología balística de primer nivel, discreción absoluta y garantía de 3 años por escrito.',
  canonicalURL = Astro.url.href,
  ogImage = '/assets/logo-white.png',
} = Astro.props;

const siteURL = 'https://www.overlapgt.com';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Overlap Guatemala",
  "description": description,
  "url": siteURL,
  "logo": `${siteURL}/assets/logo-white.png`,
  "image": `${siteURL}/assets/logo-white.png`,
  "telephone": "+50242453899",
  "email": "info@overlapgt.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Guatemala City",
    "addressCountry": "GT"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Guatemala"
  },
  "priceRange": "$$$$",
  "openingHours": "Mo-Fr 08:00-18:00",
  "sameAs": [
    `https://wa.me/50242453899`
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Niveles de Blindaje Automotriz",
    "itemListElement": [
      { "@type": "Offer", "name": "Blindaje Nivel II" },
      { "@type": "Offer", "name": "Blindaje Nivel III" },
      { "@type": "Offer", "name": "Blindaje Nivel IV" },
      { "@type": "Offer", "name": "Blindaje Nivel V" }
    ]
  }
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteURL}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Overlap Guatemala" />
    <meta property="og:locale" content="es_GT" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteURL}${ogImage}`} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0DFL9CXWD8"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0DFL9CXWD8');
    </script>
  </head>
  <body>
    <slot />

    <script>
      /* ── Scroll reveal ── */
      const revealObs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));
    </script>
  </body>
</html>
